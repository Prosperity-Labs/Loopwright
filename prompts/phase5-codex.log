+  const db = openLoopwrightDb(dbPath);
+  let worktreeId = 0;
+
+  try {
+    worktreeId = db.upsertWorktree({
+      branch_name: branchName,
+      base_branch: baseBranch,
+      status: "active",
+      task_description: options.taskPrompt,
+    });
+
+    const cycles: CycleResult[] = [];
+
+    const runAgentAndWait = async (
+      prompt: string,
